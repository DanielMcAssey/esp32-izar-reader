#pragma once

// ---------------------------------------------------------------------------
//  Copy this file to secrets.h and fill in your values.
//  secrets.h is gitignored so your credentials are not committed.
// ---------------------------------------------------------------------------

// --- WiFi ---
#define WIFI_SSID     "your-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// --- MQTT broker ---
#define MQTT_HOST "192.168.1.10"
#define MQTT_PORT 1883
#define MQTT_USER "mqtt-user"
#define MQTT_PASS "mqtt-password"

// --- OTA (over-the-air update) password ---
#define OTA_PASSWORD "change-me"

// --- Water meter ---
//  Your Diehl IZAR meter id (decimal, printed on the meter / discoverable via
//  serial when set to 0). Set to 0 during bring-up to log every meter id the
//  radio sees, then set it to your meter's id to filter to just yours.
#define METER_ID 0
